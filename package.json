{
  "name": "@actovision/kaptha-creative-suite",
  "version": "1.0.1",
  "description": "Kaptha Creative Suite — React canvas design editor",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "keywords": [
    "design",
    "editor",
    "canvas",
    "konva",
    "react",
    "creative-suite"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Actovision-ORG/kaptha-creative-suite-wrapper"
  }
}
